# Copy this file to .env and fill in your values.

DATABASE_URL=postgresql+psycopg2://user:password@host:5432/dbname?sslmode=require
REDIS_URL=
WORKERS=1
UPLOAD_FOLDER=/var/uploads
LOG_FOLDER=/var/log/CTFd
ACCESS_LOG=-
ERROR_LOG=-
REVERSE_PROXY=true

# Bounty Collab role access keys
# BNTC_EXPERT_KEY: Leave blank — experts use open enrollment (credential form only).
# BNTC_PARTNER_KEY: Set a secret key. Only users with this key can register as Company Partners.
BNTC_EXPERT_KEY=
BNTC_PARTNER_KEY=your_secret_partner_key_here
